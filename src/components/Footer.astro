---
import JoiSolutionsIcon from "../icons/JoiSolutionsIcon.astro";
const currentYear = new Date().getFullYear();
---

<footer class="footer-section" data-anim>
  <div
    class="bg-neutral-50 pt-12 pb-6 max-w-7xl mx-auto flex flex-col items-center justify-center gap-4 border border-neutral-200 rounded-t-2xl shadow-xl w-full"
  >
    <div
      class="footer-top flex flex-col md:flex-row justify-between items-start w-full text-neutral-600 px-6 md:px-20"
    >
      <div class="flex flex-col items-start md:items-center gap-4">
        <JoiSolutionsIcon class="text-4xl" showSlogan />
        <div class="flex items-center justify-between w-1/2 gap-4">
          <a href="https://www.facebook.com/share/1C7FGbsHQn/?mibextid=wwXIfr" class="text-2xl font-bold text-neutral-500 cursor-pointer cursor-trigger"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
          >
            <!-- facebook icon -->
            <i class="fab fa-facebook-f text-secondary"></i>
          </a>
          <a
            href="https://www.linkedin.com/company/joisolutions/"
            class="text-2xl font-bold text-neutral-500 cursor-pointer cursor-trigger"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <!-- linkedin icon -->
            <i class="fab fa-linkedin-in text-secondary"></i>
          </a>
          <a
            href="https://www.instagram.com/joi_solutions/?hl=es-la"
            class="text-2xl font-bold text-neutral-500 cursor-pointer cursor-trigger"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <!-- instagram icon -->
            <i class="fab fa-instagram text-secondary"></i>
          </a>
        </div>
      </div>
      <div
        class="flex flex-col md:flex-row items-start gap-10 md:gap-24 mt-10 md:mt-0"
      >
        <div>
          <h3 class="font-bold mb-2 text-base">Menu</h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a href="/nosotros" class="cursor-trigger">Nosotros</a>
            </li>
            <li>
              <a href="/productos" class="cursor-trigger">Productos</a>
            </li>
            <li>
              <a href="/contacto" class="cursor-trigger">Contacto</a>
            </li>
          </ul>
          <h3 class="font-bold mt-4 mb-2 text-base">Reclamaciones y Denuncias</h3>
          <ul class="flex flex-col gap-2">
                   <li>
              <a
                href="https://forms.office.com/Pages/ResponsePage.aspx?id=xH0UOupG0kyMdX1QvVZQXF4VTjNZuG1OmSsNIC7sqP5URFRKUjhHWkdKRE9JNDEyNlpHRVY3VFcwQi4u"
                class="cursor-trigger"
                target="_blank"
                rel="noopener noreferrer"
              >
                Libro de Reclamaciones
              </a>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold mb-2 text-base">Productos</h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a href="/joi-taq" class="cursor-trigger">Joi Taq</a>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold mb-2 text-base">Contacto</h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a
                href="mailto:info@joisolutions.io"
                class="cursor-trigger underline">info@joisolutions.io</a
              >
            </li>
            <li class="max-w-[30ch]">
              Calle Coronel Andrés Reyes 437, oficina 902, San Isidro.
            </li>
    
          </ul>
        </div>
      </div>
    </div>
    <div
      class="footer-bottom w-full flex flex-col items-start px-6 md:items-center justify-center gap-4 mt-10 border-t border-neutral-200 py-5"
    >
      <div>
        <ul class="flex flex-col md:flex-row  items-start md:items-center gap-2 md:gap-6 mb-4">
          <li>
            <a
              href="/terminos-y-condiciones"
              class="text-sm text-neutral-600 cursor-trigger"
              >Términos y Condiciones</a
            >
          </li>
          <li>
            <a
              href="/politica-de-privacidad"
              class="text-sm text-neutral-600 cursor-trigger"
              >Política de Privacidad</a
            >
          </li>
        </ul>
      </div>
      <p class="text-sm text-neutral-600 md:text-center">
        © {currentYear} JoiSolutions. <br class=" md:hidden"/> Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const footerSection = document.querySelector(".footer-section") as HTMLElement;
  const footerTop = document.querySelector(".footer-top") as HTMLElement;
  const footerBottom = document.querySelector(".footer-bottom") as HTMLElement;

  if (!prefersReduced && footerSection) {
    // Footer columns stagger rise
    const columns = footerTop?.children;
    if (columns) {
      gsap.fromTo(Array.from(columns),
        { opacity: 0, y: 30 },
        {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: "power2.out",
          scrollTrigger: { trigger: footerSection, start: "top 90%", toggleActions: "play none none none" }
        }
      );
    }

    // Bottom bar: fade in from below with delay
    if (footerBottom) {
      gsap.fromTo(footerBottom,
        { opacity: 0, y: 16 },
        {
          opacity: 1, y: 0, duration: 0.5, delay: 0.3, ease: "power2.out",
          scrollTrigger: { trigger: footerSection, start: "top 90%", toggleActions: "play none none none" }
        }
      );
    }
  }
</script>
