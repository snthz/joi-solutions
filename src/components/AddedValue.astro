---
const timelineSteps = [
  {
    title: "Seguridad financiera",
    icon: "fas fa-shield-alt",
    description:
      "Protegemos transacciones de usuarios y comercios con tecnología segura y transparente.",
    date: "01",
    highlight: true,
  },
  {
    title: "Cashless",
    icon: "fas fa-money-bill-wave",
    description:
      "Facilitamos pagos digitales para reducir el uso de efectivo y mejorar el control.",
    date: "02",
    highlight: false,
  },
  {
    title: "Cobros rápidos",
    icon: "fas fa-stopwatch",
    description:
      "Optimiza los tiempos de cobro en puntos de venta físicos con soluciones ágiles.",
    date: "03",
    highlight: false,
  },
  {
    title: "Visibilidad total",
    icon: "fas fa-chart-line",
    description:
      "Monitorea cada pago con datos en tiempo real para tomar decisiones informadas.",
    date: "04",
    highlight: true,
  },
];
---

<!-- Header -->
<div class="pt-24 pb-4 px-4 md:px-6 text-center av-header" data-anim>
  <span class="av-label inline-block text-xs font-semibold tracking-[0.2em] uppercase text-neutral-400 mb-3">Valor agregado</span>
  <h2 class="av-heading text-3xl md:text-[2.75rem] font-bold text-neutral-800 leading-tight">
    Nuestro <span class="text-tertiary">valor agregado</span>
  </h2>
  <p class="av-subheading mt-4 text-base md:text-lg text-neutral-500 max-w-[50ch] mx-auto">
    Conoce cómo nuestros productos transforman la manera de realizar pagos.
  </p>
</div>

<!-- Timeline -->
<section class="relative w-full max-w-4xl mx-auto px-6 py-16 md:py-24 overflow-hidden">
  <!-- Central line -->
  <div class="absolute left-1/2 top-0 -translate-x-1/2 hidden sm:block w-px h-full z-0">
    <div class="absolute inset-0 bg-neutral-200"></div>
    <div id="tl-progress" class="absolute left-0 top-0 w-full h-0 bg-tertiary rounded-full transition-[height] duration-100"></div>
  </div>
  <!-- Mobile left line -->
  <div class="absolute left-[2.625rem] top-0 sm:hidden w-px h-full bg-neutral-200 z-0"></div>

  <div class="relative z-10 flex flex-col gap-0">
    {timelineSteps.map((step, index) => {
      const isLeft = index % 2 === 0;
      return (
        <div class="tl-item relative" data-anim data-index={index}>
          {/* Date badge - centered on line */}
          <div class={`
            tl-date-badge
            hidden sm:flex items-center justify-center
            absolute left-1/2 -translate-x-1/2 top-0 z-20
            px-4 py-1 rounded-full text-sm font-semibold tracking-wide
            border shadow-sm
            ${step.highlight
              ? 'bg-tertiary text-white border-tertiary/60'
              : 'bg-neutral-100 text-neutral-500 border-neutral-200'
            }
          `}>
            {step.date}
          </div>
          {/* Mobile date badge */}
          <div class={`
            tl-date-badge
            sm:hidden flex items-center justify-center
            absolute left-6 top-0 z-20
            w-9 h-9 rounded-full text-xs font-bold
            ${step.highlight
              ? 'bg-tertiary text-white'
              : 'bg-neutral-100 text-neutral-500 border border-neutral-200'
            }
          `}>
            {step.date}
          </div>

          {/* Vertical segment from badge */}
          <div class="hidden sm:block absolute left-1/2 -translate-x-1/2 top-8 w-px h-8 bg-neutral-200 z-10"></div>
          <div class="sm:hidden absolute left-[2.625rem] top-9 w-px h-6 bg-neutral-200 z-10"></div>

          {/* Content card */}
          <div class={`
            tl-card
            pt-16 sm:pt-20 pb-12
            sm:w-[calc(50%-2rem)]
            ${isLeft ? 'sm:mr-auto sm:pr-0 sm:text-right' : 'sm:ml-auto sm:pl-0 sm:text-left'}
            pl-16 sm:pl-0
          `}>
            <div class="flex items-center gap-3 mb-3 sm:justify-start" style={isLeft ? '' : ''}>
              <div class={`
                w-10 h-10 rounded-xl flex items-center justify-center shrink-0
                ${step.highlight ? 'bg-tertiary/10 text-tertiary' : 'bg-neutral-100 text-neutral-400'}
              `}>
                <i class={`${step.icon} text-lg`}></i>
              </div>
              <h4 class="font-semibold text-lg md:text-xl text-neutral-800 tracking-tight uppercase">
                {step.title}
              </h4>
            </div>
            <p class="text-sm md:text-base text-neutral-500 leading-relaxed max-w-sm sm:text-left">
              {step.description}
            </p>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .tl-item { opacity: 0; }
  .tl-date-badge { opacity: 0; transform: scale(0.8); }
  .av-heading, .av-subheading, .av-label { opacity: 0; }

  @media (prefers-reduced-motion: reduce) {
    .tl-item, .tl-date-badge, .av-heading, .av-subheading, .av-label {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Header entrance ---
  const avLabel = document.querySelector('.av-label') as HTMLElement;
  const avHeading = document.querySelector('.av-heading') as HTMLElement;
  const avSubheading = document.querySelector('.av-subheading') as HTMLElement;

  if (!prefersReduced && avHeading) {
    const headerTl = gsap.timeline({
      scrollTrigger: { trigger: avHeading, start: 'top 85%', toggleActions: 'play none none none' }
    });
    headerTl
      .fromTo(avLabel, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' })
      .fromTo(avHeading, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.2')
      .fromTo(avSubheading, { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3');
  } else {
    gsap.set([avLabel, avHeading, avSubheading], { opacity: 1, y: 0 });
  }

  // --- Timeline items: staggered slide-in from alternating sides ---
  const items = document.querySelectorAll('.tl-item') as NodeListOf<HTMLElement>;
  if (!prefersReduced) {
    items.forEach((el, i) => {
      const isLeft = i % 2 === 0;
      const card = el.querySelector('.tl-card') as HTMLElement;
      const badge = el.querySelector('.tl-date-badge') as HTMLElement;
      const badges = el.querySelectorAll('.tl-date-badge');

      // Item fade in
      gsap.fromTo(el,
        { opacity: 0 },
        {
          opacity: 1, duration: 0.5, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
        }
      );

      // Card slides from its side
      if (card) {
        const xFrom = isLeft ? -40 : 40;
        gsap.fromTo(card,
          { opacity: 0, x: xFrom },
          {
            opacity: 1, x: 0, duration: 0.7, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
          }
        );
      }

      // Date badges pop in
      badges.forEach((b) => {
        gsap.fromTo(b,
          { opacity: 0, scale: 0.7 },
          {
            opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(2)', delay: 0.15,
            scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
          }
        );
      });
    });
  } else {
    items.forEach((el) => { el.style.opacity = '1'; });
    document.querySelectorAll('.tl-date-badge').forEach((b) => {
      (b as HTMLElement).style.opacity = '1';
      (b as HTMLElement).style.transform = 'none';
    });
  }

  // --- Progress line draw (desktop only) ---
  const progressEl = document.getElementById('tl-progress');
  if (progressEl && !prefersReduced && window.matchMedia('(min-width: 640px)').matches) {
    const section = progressEl.closest('section');
    ScrollTrigger.create({
      trigger: section,
      start: 'top 20%',
      end: 'bottom 80%',
      onUpdate: (self) => {
        progressEl.style.height = `${Math.max(0, Math.min(1, self.progress)) * 100}%`;
      }
    });
  }
</script>
