---
import { Image } from "astro:assets";
import JoiSolutionsIcon from "../icons/JoiSolutionsIcon.astro";
import unionImage from "../assets/tech-partnership.png"; // reemplaza esto por la imagen ilustrativa que elijas
---

<section class="w-full bg-white py-10 my-10 px-4 md:px-6">
  <div
    class="redjoi-card max-w-screen-xl mx-auto flex flex-col md:flex-row gap-10 md:gap-14 items-center bg-neutral-50 rounded-3xl border border-neutral-200"
  >
    <!-- Imagen ilustrativa de la fusión -->
    <div
      class="w-full md:w-1/2 h-full bg-tertiary/80 rounded-t-3xl md:rounded-t-none md:rounded-l-3xl flex items-center justify-center p-10 md:py-20"
    >
      <div class="overflow-hidden rounded-xl shadow-md">
        <Image
          src={unionImage}
          width={400}
          height={500}
          alt="Ilustración de colaboración entre empresas"
          class="object-cover w-full h-full"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Texto de la fusión -->
    <div
      class="redjoi-text w-full md:w-1/2 space-y-6 p-6 flex flex-col items-center md:items-start"
    >
      <div
        class="flex flex-col md:flex-row items-center gap-0 md:gap-4 justify-start mb-6 md:mb-2 text-[2.5em]"
      >
        <JoiSolutionsIcon class="text-neutral-700" />
      </div>
      <p
        class="text-neutral-600 text-sm md:text-lg text-center md:text-left mb-10"
      >
        JoiSolutions es una empresa con más de 10 años
        de experiencia desarrollando tecnología para medios de pago en América Latina.
        Creando soluciones que responden a los retos actuales de empresas e instituciones
        con una lógica más ágil, escalable y centrada en el impacto, ofreciendo soluciones tecnológicas<span
          class="text-tertiary font-bold">.</span
        >
      </p>
      <a
        href="/productos"
        class="bg-primary px-8 text-sm md:text-lg text-white py-3 rounded-full shadow-lg cursor-trigger cursor-pointer relative z-[40]"
      >
        <span class="relative z-[60] font-medium"
          >Descubre nuestros productos</span
        >
        <i class="fa-solid fa-arrow-right text-tertiary ml-2"></i>
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced) {
    const card = document.querySelector(".redjoi-card") as HTMLElement;
    const text = document.querySelector(".redjoi-text") as HTMLElement;

    if (card) {
      gsap.fromTo(card,
        { opacity: 0, y: 50, scale: 0.96 },
        {
          opacity: 1, y: 0, scale: 1, duration: 1, ease: "power3.out",
          scrollTrigger: { trigger: card, start: "top 82%", toggleActions: "play none none none" },
        }
      );
    }

    if (text) {
      const children = text.children;
      gsap.fromTo(children,
        { opacity: 0, y: 20 },
        {
          opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: "power3.out",
          scrollTrigger: { trigger: text, start: "top 80%", toggleActions: "play none none none" },
        }
      );
    }
  }
</script>
