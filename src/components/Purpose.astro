<section
  class="py-20 w-full flex items-center justify-center relative overflow-hidden border-t bg-white border-neutral-200"
>
  <div
    class="flex flex-col items-center justify-center max-w-screen-xl mx-auto px-4 py-32"
  >
    <div
      class="border px-6 py-1 rounded-full text-center text-neutral-500 text-sm md:text-lg mb-6 font-medium bg-neutral-50 border-neutral-200 shadow-2xl"
    >
      <span class="flex items-center gap-1">Nuestro propósito</span>
    </div>
    <p
      class="text-xl md:text-3xl 3xl:text-4xl font-medium text-neutral-700 leading-[1.3em] mb-4 animate-quote text-center max-w-[50ch]"
    >
      Nuestro propósito es acelerar el crecimiento de sectores claves,
      derribando barreras operativas y creando experiencias que impulsan
      impacto, evolución continua y progreso compartido.<span
        class="text-tertiary font-black">.</span
      >
    </p>
  </div>
  <div
    class="absolute -bottom-[5em] md:-bottom-[10em] left-1/2 h-[5em] w-[5em] md:h-[10em] md:w-[10em] rounded-full bg-tertiary/80 -translate-x-1/2 -translate-y-1/2"
  >
  </div>

  <script>
    import gsap from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(SplitText, ScrollTrigger);

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const animateQuote = document.querySelector(".animate-quote");

    if (animateQuote && !prefersReduced) {
      const splitText = new SplitText(animateQuote, {
        type: "words",
        aria: "hidden",
      });

      const words = splitText.words;

      gsap.fromTo(words,
        { opacity: 0, y: 16, filter: "blur(3px)" },
        {
          opacity: 1,
          y: 0,
          filter: "blur(0px)",
          stagger: 0.025,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: animateQuote,
            start: "top 82%",
            end: "top 20%",
            toggleActions: "play none none reverse",
          },
        }
      );

      // Animate the decorative circle
      const circle = animateQuote?.closest("section")?.querySelector(".absolute.-bottom-\\[5em\\], .absolute.-bottom-\\[10em\\]") || animateQuote?.closest("section")?.querySelector("div[class*='rounded-full'][class*='bg-tertiary']");
      if (circle) {
        gsap.fromTo(circle,
          { scale: 0, opacity: 0 },
          {
            scale: 1, opacity: 1, duration: 1.2, ease: "power2.out",
            scrollTrigger: { trigger: animateQuote, start: "top 60%", toggleActions: "play none none reverse" },
          }
        );
      }
    }
  </script>
</section>
