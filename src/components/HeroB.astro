---
/**
 * Hero B — Elegant / Editorial Variant
 * Asymmetric layout, editorial typography, gradient text accent,
 * clean minimal background, parallax-scroll depth.
 *
 * To use: replace `<Hero />` with `<HeroB />` in pages/index.astro
 */
import { Image } from "astro:assets";
import JoiDevice from "../assets/devices.png";
import Solutions from "./Solutions.astro";
---

<section class="herob-section relative overflow-hidden bg-white min-h-screen flex flex-col">
  <!-- Background -->
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 opacity-40" style="background-image: linear-gradient(rgba(32,57,111,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(32,57,111,0.035) 1px, transparent 1px); background-size: 80px 80px;"></div>
    <!-- Soft gradient orb -->
    <div class="herob-orb absolute top-[15%] right-[10%] w-125 h-125 rounded-full bg-tertiary/6 blur-[100px]"></div>
    <div class="herob-orb-2 absolute bottom-[10%] left-[5%] w-100 h-100 rounded-full bg-primary/4 blur-[80px]"></div>
    <!-- Fine horizontal rules -->
    <div class="absolute top-1/3 left-0 w-full h-px bg-neutral-200/40"></div>
    <div class="absolute top-2/3 left-0 w-full h-px bg-neutral-200/30"></div>
  </div>

  <div
    class="w-full max-w-7xl mx-auto px-6 md:px-10 pt-40 md:pt-48 pb-20 md:pb-28 flex flex-col items-center relative flex-1"
  >
    <!-- Centered editorial layout -->
    <div class="text-center max-w-4xl relative z-10 flex flex-col items-center">
      <!-- Subtle label -->
      <div class="herob-label inline-flex items-center gap-3 mb-10">
        <span class="w-8 h-px bg-tertiary"></span>
        <span class="text-xs uppercase tracking-[0.25em] font-semibold text-neutral-400">Tecnología NFC</span>
        <span class="w-8 h-px bg-tertiary"></span>
      </div>

      <h1 class="herob-title text-4xl md:text-6xl lg:text-7xl font-bold text-neutral-800 leading-[1.08] tracking-tight">
        Crea experiencias de pago
        <span class="herob-gradient-text bg-clip-text text-transparent bg-linear-to-r from-tertiary via-tertiary-dark to-primary">simples</span>
        y seguras<span class="text-tertiary">.</span>
      </h1>

      <!-- Thin divider line -->
      <div class="herob-divider w-20 h-0.5 bg-linear-to-r from-tertiary to-primary/60 mx-auto mt-8 mb-6" aria-hidden="true"></div>

      <p class="herob-subtitle text-neutral-500 text-lg md:text-xl max-w-2xl leading-relaxed mx-auto">
        Tecnología innovadora que conecta a las personas para simplificar la
        vida, con alegría.
      </p>

      <div class="herob-cta mt-12 flex flex-wrap items-center justify-center gap-5">
        <a
          href="/contacto"
          class="herob-cta-btn group bg-neutral-900 text-white px-9 py-4 rounded-full text-lg font-medium transition-all duration-300 cursor-trigger relative overflow-hidden"
        >
          <span class="relative z-10">¡Conversemos!</span>
          <div class="absolute inset-0 bg-primary opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </a>
        <a
          href="/joi-taq"
          class="group inline-flex items-center gap-2 px-7 py-4 text-neutral-600 font-medium transition-all duration-300 hover:text-primary cursor-trigger"
        >
          <span>Ver Joi Taq</span>
          <i class="fa-solid fa-arrow-right text-tertiary text-sm transition-transform duration-300 group-hover:translate-x-2"></i>
        </a>
      </div>
    </div>

    <!-- Device image: full-width editorial placement below -->
    <div class="herob-device w-full max-w-3xl mt-16 md:mt-20 relative">
      <!-- Ambient shadow -->
      <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-[70%] h-16 bg-neutral-900/5 rounded-full blur-2xl" aria-hidden="true"></div>
      
      <Image
        src={JoiDevice}
        width={1200}
        height={800}
        alt="Dispositivos Joi Solutions — Pulsera NFC y tarjeta para pagos contactless seguros"
        class="w-full h-auto object-contain relative z-10"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Floating stat badges — editorial style -->
      <div class="herob-stat absolute right-0 md:right-8 top-1/4 bg-white/90 backdrop-blur-md rounded-2xl shadow-xl border border-neutral-100 px-5 py-3 z-20">
        <div class="text-2xl font-bold text-primary">NFC</div>
        <div class="text-xs text-neutral-500">Contactless</div>
      </div>

      <div class="herob-stat-2 absolute left-0 md:left-8 bottom-1/4 bg-white/90 backdrop-blur-md rounded-2xl shadow-xl border border-neutral-100 px-5 py-3 z-20">
        <div class="text-2xl font-bold text-tertiary">100%</div>
        <div class="text-xs text-neutral-500">Seguro</div>
      </div>
    </div>
  </div>

  <Solutions />
</section>

<style>
  .herob-gradient-text {
    -webkit-background-clip: text;
    background-clip: text;
  }
  .herob-label, .herob-title, .herob-divider, .herob-subtitle, .herob-cta, .herob-device, .herob-stat, .herob-stat-2 {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .herob-label, .herob-title, .herob-divider, .herob-subtitle, .herob-cta, .herob-device, .herob-stat, .herob-stat-2 {
      opacity: 1 !important;
      transform: none !important;
      clip-path: none !important;
    }
  }
</style>

<script>
  import gsap from "gsap";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced) {
    const tl = gsap.timeline({
      defaults: { duration: 0.9, ease: "power3.out" },
    });

    // Editorial staggered reveal — more restrained, elegant timing
    tl.fromTo(".herob-label",
        { opacity: 0, y: -8 },
        { opacity: 1, y: 0, duration: 0.6 }, 0.2)
      // Title: clip-path reveal from bottom
      .fromTo(".herob-title",
        { opacity: 0, clipPath: "inset(100% 0 0 0)" },
        { opacity: 1, clipPath: "inset(0% 0 0 0)", duration: 1, ease: "power3.inOut" }, 0.3)
      .fromTo(".herob-divider",
        { opacity: 0, scaleX: 0 },
        { opacity: 1, scaleX: 1, transformOrigin: "center", duration: 0.7 }, 0.8)
      .fromTo(".herob-subtitle",
        { opacity: 0, y: 16 },
        { opacity: 1, y: 0, duration: 0.8 }, 0.9)
      .fromTo(".herob-cta",
        { opacity: 0, y: 12 },
        { opacity: 1, y: 0, duration: 0.6 }, 1.1)
      // Device: elegant scale-up from below
      .fromTo(".herob-device",
        { opacity: 0, y: 60, scale: 0.96 },
        { opacity: 1, y: 0, scale: 1, duration: 1.2, ease: "power2.out" }, 0.6)
      // Stat badges: staggered pop
      .fromTo(".herob-stat",
        { opacity: 0, x: 20, scale: 0.9 },
        { opacity: 1, x: 0, scale: 1, duration: 0.5, ease: "back.out(1.2)" }, 1.3)
      .fromTo(".herob-stat-2",
        { opacity: 0, x: -20, scale: 0.9 },
        { opacity: 1, x: 0, scale: 1, duration: 0.5, ease: "back.out(1.2)" }, 1.4);

    // Orb drift
    gsap.to(".herob-orb", {
      x: 20, y: -15, duration: 10, repeat: -1, yoyo: true, ease: "sine.inOut",
    });
    gsap.to(".herob-orb-2", {
      x: -15, y: 10, duration: 12, repeat: -1, yoyo: true, ease: "sine.inOut",
    });

    // Device parallax on scroll
    gsap.to(".herob-device", {
      yPercent: -5,
      ease: "none",
      scrollTrigger: {
        trigger: ".herob-section",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });

    // Stat badges: subtle float
    gsap.to(".herob-stat", {
      y: -4, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut",
    });
    gsap.to(".herob-stat-2", {
      y: 4, duration: 3, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 0.5,
    });

    // CTA magnetic hover
    const ctaBtn = document.querySelector(".herob-cta-btn") as HTMLElement;
    if (ctaBtn) {
      ctaBtn.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = ctaBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(ctaBtn, { x: x * 0.12, y: y * 0.12, duration: 0.3, ease: "power2.out" });
      });
      ctaBtn.addEventListener("mouseleave", () => {
        gsap.to(ctaBtn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1, 0.4)" });
      });
    }
  } else {
    gsap.set([".herob-label", ".herob-title", ".herob-divider", ".herob-subtitle", ".herob-cta", ".herob-device", ".herob-stat", ".herob-stat-2"], {
      opacity: 1, y: 0, x: 0, scale: 1, scaleX: 1, clipPath: "none",
    });
  }
</script>
