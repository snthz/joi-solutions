---
import { Image } from "astro:assets";
import JoiYellow from "../assets/joi-yellow.png";
import deviceImage from "../assets/device.png";
const {
  showImage = false,
  title = "¿Quieres saber más sobre nosotros?",
  description = "Descubre cómo nuestros productos pueden transformar tu forma de interactuar y crecer en el mundo digital.",
} = Astro.props;
---

<section class="px-4 md:px-6 cta-section" data-anim>
  <div
    class="cta-card bg-linear-to-br from-neutral-50 to-white px-2 shadow-xl border border-neutral-200 max-w-7xl mx-auto flex flex-col items-center justify-between md:px-2 rounded-2xl relative my-10 overflow-hidden mb-20"
  >
    <div class="flex items-center w-full gap-4 py-12 md:py-16">
      <div
        class="flex flex-col items-center justify-center text-neutral-700 md:w-3/4 mx-auto gap-3 z-10"
      >
        <span
          class="text-2xl md:text-5xl font-bold leading-[1.4em] text-center text-balance"
        >
          {title}
        </span>
        <small class="text-sm md:text-xl text-center text-balance text-neutral-500 max-w-[60ch]">
          {description}
        </small>
        <a
          href="/contacto"
          class="cta-main group bg-primary text-sm md:text-lg px-8 mt-8 text-white py-3.5 rounded-full shadow-lg shadow-primary/20 cursor-trigger cursor-pointer relative z-10 overflow-hidden transition-all duration-300"
        >
          <span class="relative z-10 font-medium">Contáctanos</span>
          <i class="fa-solid fa-arrow-right text-tertiary ml-2 relative z-10 transition-transform duration-300 group-hover:translate-x-1"></i>
          <div class="absolute inset-0 bg-linear-to-r from-primary to-primary/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
      </div>
    </div>
    {
      showImage && (
        <div class="mt-10 w-full flex items-center justify-center relative">
          <Image
            src={deviceImage}
            alt="Dispositivo Joi Solutions para pagos contactless"
            class="relative opacity-100 z-10 rounded-t-xl block border border-neutral-200"
            loading="lazy"
            width={800}
            height={800}
          />
        </div>
      )
    }
    <!-- BG Joi -->
    <div class="w-full absolute flex items-center justify-center h-full opacity-30 md:opacity-50" aria-hidden="true">
      <Image
        src={JoiYellow}
        alt=""
        class="w-full h-full object-cover opacity-30"
        loading="lazy"
        width={1920}
        height={1080}
      />
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // --- CTA card: scale-up entrance from 0.92 ---
  const ctaCard = document.querySelector(".cta-card") as HTMLElement;
  if (ctaCard && !prefersReduced) {
    gsap.fromTo(ctaCard,
      { opacity: 0, scale: 0.92, y: 30 },
      {
        opacity: 1, scale: 1, y: 0, duration: 0.9, ease: "power3.out",
        scrollTrigger: { trigger: ctaCard, start: "top 82%", toggleActions: "play none none none" }
      }
    );
  }

  // --- CTA button: magnetic hover effect ---
  if (!prefersReduced) {
    document.querySelectorAll(".cta-main").forEach((btn) => {
      const el = btn as HTMLElement;
      el.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(el, {
          x: x * 0.2,
          y: y * 0.2,
          scale: 1.05,
          boxShadow: "0 12px 36px rgba(32,57,111,0.28)",
          duration: 0.3,
          ease: "power2.out",
        });
      });
      el.addEventListener("mouseleave", () => {
        gsap.to(el, {
          x: 0,
          y: 0,
          scale: 1,
          boxShadow: "0 4px 14px rgba(32,57,111,0.2)",
          duration: 0.4,
          ease: "elastic.out(1, 0.5)",
        });
      });
    });
  }
</script>
