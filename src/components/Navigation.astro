---
import LogoIcon from "../icons/JoiSolutionsIcon.astro";

const links = [
  { name: "Inicio", href: "/" },
  { name: "Nosotros", href: "/nosotros" },
  { name: "Joi Taq", href: "/joi-taq" },
];
---

<header class="fixed top-0 left-0 w-full z-60 px-4 pt-3 md:pt-4">
  <nav
    class="nav-container max-w-5xl 3xl:max-w-6xl mx-auto flex items-center justify-between px-5 md:px-6 py-3 rounded-2xl bg-white/80 backdrop-blur-md border border-neutral-200/50 shadow-[0_1px_6px_rgba(0,0,0,0.03)] relative"
  >
    <!-- Logo -->
    <a href="/" class="cursor-pointer shrink-0">
      <LogoIcon class="text-[1.5em] md:text-[1.7em]" />
    </a>

    <!-- Desktop: centered links -->
    <ul class="hidden md:flex items-center gap-0.5 absolute left-1/2 -translate-x-1/2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="px-5 py-2 text-sm font-medium text-neutral-500 rounded-full link transition-all duration-200 hover:text-primary hover:bg-neutral-50"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right actions -->
    <div class="flex items-center gap-3">
      <a
        href="/contacto"
        class="nav-cta hidden md:inline-flex items-center gap-2 bg-primary text-white px-6 py-2.5 rounded-full text-sm font-medium cursor-trigger shadow-sm transition-all duration-300 hover:shadow-md hover:shadow-primary/15"
      >
        Conversemos
        <i class="fa-solid fa-arrow-right text-tertiary text-[10px]"></i>
      </a>
      <button id="nav-menu" class="bg-primary p-2.5 rounded-full md:hidden z-50">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div
    id="mobile-menu"
    class="fixed top-[-150%] left-0 w-full h-dvh bg-white z-50 flex flex-col gap-6 px-6 py-8 transition-all md:hidden"
  >
    <div class="flex justify-between items-center">
      <a href="/">
        <LogoIcon class="text-[1.8em]" />
      </a>
      <button id="close-menu" class="p-2 rounded-full hover:bg-neutral-100 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <ul class="flex flex-col gap-4 mt-6">
      {
        links.map((link) => (
          <li class="py-5 border-b border-neutral-200 flex items-center justify-between">
            <a href={link.href} class="text-xl font-medium text-neutral-700">{link.name}</a>
            <i class="fas fa-chevron-right text-tertiary ml-2"></i>
          </li>
        ))
      }
    </ul>

    <a href="/contacto" class="mt-auto bg-primary text-white text-center py-3 rounded-full font-medium">
      Conversemos
    </a>
  </div>
</header>

<style>
  .link-active {
    background-color: var(--color-primary);
    color: #fff;
  }
  .nav-scrolled {
    background-color: rgba(255, 255, 255, 0.95) !important;
    border-color: rgba(0, 0, 0, 0.06) !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06) !important;
  }
  .nav-container {
    opacity: 0;
    transform: translateY(-12px);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-container { opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const $ = (selector: string) => document.querySelector(selector);
  const navContainer = $(".nav-container") as HTMLElement;
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Nav entrance
  if (!prefersReduced && navContainer) {
    gsap.fromTo(navContainer,
      { opacity: 0, y: -12 },
      { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", delay: 0.1 }
    );
  } else if (navContainer) {
    navContainer.style.opacity = "1";
    navContainer.style.transform = "none";
  }

  // Scroll: enhance bg
  ScrollTrigger.create({
    start: "top -40",
    onEnter: () => navContainer?.classList.add("nav-scrolled"),
    onLeaveBack: () => navContainer?.classList.remove("nav-scrolled"),
  });

  // Active link
  const currentPath = window.location.pathname;
  document.querySelectorAll(".link").forEach((link) => {
    if (link.getAttribute("href") === currentPath) {
      link.classList.add("link-active");
    }
  });

  // Nav CTA: magnetic hover
  const navCta = $(".nav-cta") as HTMLElement;
  if (navCta && !prefersReduced) {
    navCta.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = navCta.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(navCta, { x: x * 0.1, y: y * 0.1, scale: 1.04, duration: 0.25, ease: "power2.out" });
    });
    navCta.addEventListener("mouseleave", () => {
      gsap.to(navCta, { x: 0, y: 0, scale: 1, duration: 0.3, ease: "elastic.out(1, 0.5)" });
    });
  }

  // Mobile menu
  const openBtn = $("#nav-menu") as HTMLButtonElement;
  const closeBtn = $("#close-menu") as HTMLButtonElement;
  const mobileMenu = $("#mobile-menu") as HTMLDivElement;

  if (openBtn && closeBtn && mobileMenu) {
    const mobileLinks = mobileMenu.querySelectorAll("li");

    openBtn.addEventListener("click", () => {
      mobileMenu.style.top = "0";
      mobileMenu.style.transition = "top 0.5s cubic-bezier(0.4,0,0.2,1)";
      if (!prefersReduced) {
        gsap.fromTo(mobileLinks,
          { opacity: 0, x: -20 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "power2.out", delay: 0.3 }
        );
      }
    });

    closeBtn.addEventListener("click", () => {
      mobileMenu.style.top = "-150%";
      mobileMenu.style.transition = "top 0.5s cubic-bezier(0.4,0,0.2,1)";
    });
  }
</script>