---
import { Image } from "astro:assets";
import JoiDevice from "../assets/devices.png";
---

<section class="hero-section relative overflow-hidden bg-white min-h-screen flex flex-col">
  <!-- Background: Grid pattern with colored cells (Meizon style) -->
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
    <!-- Grid lines -->
    <div
      class="hero-grid absolute inset-0 opacity-0"
      style="background-image: linear-gradient(rgba(0,0,0,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.035) 1px, transparent 1px); background-size: 80px 80px;"
    ></div>
    <!-- Top fade so grid is subtle at top -->
    <div class="absolute top-0 left-0 right-0 h-[35%] bg-linear-to-b from-white via-white/80 to-transparent z-[1]"></div>
    <!-- Colored grid cells — scattered like Meizon's yellow squares -->
    <div class="hero-cells hidden md:block">
      <div class="absolute w-20 h-20 bg-tertiary/10 rounded-sm" style="top: 50%; left: 10%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/8 rounded-sm" style="top: 58%; left: 25%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/12 rounded-sm" style="top: 64%; right: 15%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/6 rounded-sm" style="top: 56%; right: 30%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/8 rounded-sm" style="top: 72%; left: 38%;"></div>
      <div class="absolute w-20 h-20 bg-primary/4 rounded-sm" style="top: 70%; left: 15%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/10 rounded-sm" style="top: 76%; right: 20%;"></div>
      <div class="absolute w-20 h-20 bg-primary/3 rounded-sm" style="top: 66%; left: 52%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/6 rounded-sm" style="top: 80%; right: 40%;"></div>
      <div class="absolute w-20 h-20 bg-tertiary/10 rounded-sm" style="top: 44%; right: 8%;"></div>
    </div>
    <!-- Mobile: fewer cells -->
    <div class="hero-cells md:hidden">
      <div class="absolute w-16 h-16 bg-tertiary/10 rounded-sm" style="top: 55%; left: 5%;"></div>
      <div class="absolute w-16 h-16 bg-tertiary/8 rounded-sm" style="top: 65%; right: 8%;"></div>
      <div class="absolute w-16 h-16 bg-tertiary/12 rounded-sm" style="top: 75%; left: 30%;"></div>
      <div class="absolute w-16 h-16 bg-primary/4 rounded-sm" style="top: 70%; right: 25%;"></div>
    </div>
  </div>

  <!-- Centered content -->
  <div class="w-full max-w-3xl mx-auto px-6 pt-32 md:pt-40 pb-8 flex flex-col items-center text-center relative z-10">
    <!-- Badge (like Meizon's star badge) -->
    <div class="hero-badge inline-flex items-center gap-2.5 px-5 py-2 rounded-full border border-neutral-200/80 bg-white/90 backdrop-blur-sm shadow-[0_1px_3px_rgba(0,0,0,0.04)] mb-8">
      <span class="w-5 h-5 bg-tertiary/15 rounded-full flex items-center justify-center">
        <i class="fas fa-star text-tertiary text-[10px]"></i>
      </span>
      <span class="text-sm font-medium text-neutral-600">Tecnología NFC para pagos simples</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-title text-[2.25rem] md:text-[3.25rem] lg:text-[3.75rem] font-bold text-neutral-900 leading-[1.08] tracking-tight">
      Crea experiencias de pago <span class="text-tertiary">simples</span> y seguras<span class="text-tertiary">.</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle text-neutral-500 text-base md:text-lg mt-6 max-w-xl leading-relaxed">
      Tecnología innovadora que conecta a las personas para simplificar la vida, con alegría.
    </p>

    <!-- Primary CTA (gold/yellow like Meizon) -->
    <div class="hero-cta mt-10">
      <a
        href="/contacto"
        class="hero-cta-primary group inline-flex items-center gap-2 bg-tertiary text-neutral-900 px-9 py-3.5 rounded-full shadow-lg shadow-tertiary/20 text-base font-semibold cursor-trigger relative overflow-hidden transition-all duration-300 hover:shadow-tertiary/30 hover:shadow-xl"
      >
        <span class="relative z-10">¡Conversemos!</span>
      </a>
    </div>

    <!-- Email input bar (like Meizon's "Enter your E-mail" + "Request a demo") -->
    <div class="hero-input mt-6 flex items-center bg-white border border-neutral-300/70 rounded-full p-1.5 shadow-sm w-full max-w-md">
      <input
        type="email"
        placeholder="Ingresa tu correo"
        class="flex-1 px-4 py-2 text-sm text-neutral-700 bg-transparent outline-none placeholder-neutral-400 min-w-0"
      />
      <a
        href="/contacto"
        class="bg-primary text-white px-5 py-2.5 rounded-full text-sm font-medium whitespace-nowrap shrink-0 transition-all duration-200 hover:bg-primary/90"
      >
        Solicitar demo
      </a>
    </div>
    <p class="hero-hint text-xs text-neutral-400 mt-2.5">Prueba tu demo gratuita sin compromiso.</p>
  </div>

  <!-- Device showcase: centered below content, in the grid zone -->
  <div class="relative w-full max-w-4xl mx-auto px-6 pb-6 z-10">
    <div class="hero-device relative flex items-center justify-center">
      <Image
        src={JoiDevice}
        width={1200}
        height={800}
        alt="Dispositivos Joi Solutions — Pulsera NFC y tarjeta para pagos contactless seguros"
        class="w-full max-w-3xl h-auto object-contain relative z-10 drop-shadow-[0_20px_40px_rgba(0,0,0,0.08)]"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Float badge: Contactless -->
      <div class="hero-float-badge absolute -right-2 md:right-8 top-1/4 bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.06)] border border-neutral-100/80 px-3.5 py-2.5 flex items-center gap-2.5 z-20">
        <div class="w-8 h-8 bg-tertiary/10 rounded-lg flex items-center justify-center">
          <i class="fa-brands fa-nfc-symbol text-tertiary text-sm"></i>
        </div>
        <span class="text-xs font-semibold text-neutral-700 hidden sm:block">Contactless</span>
      </div>

      <!-- Float badge: Seguro -->
      <div class="hero-float-badge-2 absolute -left-2 md:left-8 bottom-1/4 bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.06)] border border-neutral-100/80 px-3.5 py-2.5 flex items-center gap-2.5 z-20">
        <div class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center">
          <i class="fas fa-shield-alt text-primary text-sm"></i>
        </div>
        <span class="text-xs font-semibold text-neutral-700 hidden sm:block">Seguro</span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced) {
    const tl = gsap.timeline({
      defaults: { duration: 0.8, ease: "power3.out" },
    });

    // Grid fade in
    tl.fromTo(".hero-grid", { opacity: 0 }, { opacity: 1, duration: 1.5, ease: "power1.in" }, 0)

    // Badge: pop
    .fromTo(".hero-badge", { opacity: 0, y: -12, scale: 0.92 }, { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: "back.out(1.3)" }, 0.1)

    // Title: slide up
    .fromTo(".hero-title", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, 0.25)

    // Subtitle
    .fromTo(".hero-subtitle", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.7 }, 0.5)

    // CTA
    .fromTo(".hero-cta", { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.5 }, 0.65)

    // Input bar
    .fromTo(".hero-input", { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 }, 0.75)
    .fromTo(".hero-hint", { opacity: 0 }, { opacity: 1, duration: 0.4 }, 0.85)

    // Device: rise from below
    .fromTo(".hero-device", { opacity: 0, y: 50, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 1.1, ease: "power2.out" }, 0.6)

    // Float badges: pop in
    .fromTo(".hero-float-badge", { opacity: 0, x: 20, scale: 0.85 }, { opacity: 1, x: 0, scale: 1, duration: 0.45, ease: "back.out(1.5)" }, 1.2)
    .fromTo(".hero-float-badge-2", { opacity: 0, x: -20, scale: 0.85 }, { opacity: 1, x: 0, scale: 1, duration: 0.45, ease: "back.out(1.5)" }, 1.3);

    // Colored cells: stagger fade in
    gsap.fromTo(".hero-cells > div", { opacity: 0, scale: 0.6 }, {
      opacity: 1, scale: 1, duration: 0.6, stagger: 0.08, ease: "power2.out", delay: 0.8
    });

    // Device: subtle float
    gsap.to(".hero-device img", {
      y: -6, duration: 3.5, repeat: -1, yoyo: true, ease: "sine.inOut",
    });

    // Float badges: gentle hover
    gsap.to(".hero-float-badge", {
      y: -4, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 0.5,
    });
    gsap.to(".hero-float-badge-2", {
      y: 4, duration: 2.8, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 0.8,
    });

    // CTA: magnetic hover
    const ctaBtn = document.querySelector(".hero-cta-primary") as HTMLElement;
    if (ctaBtn) {
      ctaBtn.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = ctaBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(ctaBtn, { x: x * 0.12, y: y * 0.12, scale: 1.03, duration: 0.25, ease: "power2.out" });
      });
      ctaBtn.addEventListener("mouseleave", () => {
        gsap.to(ctaBtn, { x: 0, y: 0, scale: 1, duration: 0.35, ease: "elastic.out(1, 0.5)" });
      });
    }
  } else {
    gsap.set([".hero-grid", ".hero-badge", ".hero-title", ".hero-subtitle", ".hero-cta", ".hero-input", ".hero-hint", ".hero-device", ".hero-float-badge", ".hero-float-badge-2"], { opacity: 1, y: 0, x: 0, scale: 1 });
    gsap.set(".hero-cells > div", { opacity: 1, scale: 1 });
  }
</script>
