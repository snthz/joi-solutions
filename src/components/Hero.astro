---
import { Image } from "astro:assets";
import JoiDevice from "../assets/devices.png";
---

<section class="hero-section relative overflow-hidden min-h-screen flex flex-col" style="background: white;">
  <!-- Particle canvas -->
  <canvas id="hero-particles" class="absolute inset-0 w-full h-full z-[2] pointer-events-none"></canvas>

  <!-- Background layers -->
  <div class="absolute inset-0 z-[1] pointer-events-none" aria-hidden="true">
    <!-- Subtle grid -->
    <div
      class="hero-grid absolute inset-0 opacity-0"
      style="background-image: linear-gradient(rgba(32,57,111,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(32,57,111,0.035) 1px, transparent 1px); background-size: 80px 80px;"
    ></div>

    <!-- Soft ambient glow orbs — just 2, very gentle -->
    <div class="hero-orb hero-orb-1 absolute w-[600px] h-[600px] rounded-full opacity-0" style="top: -5%; left: -10%; background: radial-gradient(circle, rgba(253,198,50,0.12) 0%, rgba(253,198,50,0.04) 50%, transparent 70%);"></div>
    <div class="hero-orb hero-orb-2 absolute w-[700px] h-[700px] rounded-full opacity-0" style="bottom: -10%; right: -15%; background: radial-gradient(circle, rgba(32,57,111,0.08) 0%, rgba(32,57,111,0.03) 50%, transparent 70%);"></div>

    <!-- A few small floating dots -->
    <div class="hero-dot hidden md:block absolute w-1.5 h-1.5 rounded-full bg-tertiary/30" style="top: 22%; left: 15%;"></div>
    <div class="hero-dot hidden md:block absolute w-1 h-1 rounded-full bg-primary/20" style="top: 35%; right: 18%;"></div>
    <div class="hero-dot hidden md:block absolute w-2 h-2 rounded-full bg-tertiary/20" style="top: 60%; left: 8%;"></div>
    <div class="hero-dot hidden md:block absolute w-1 h-1 rounded-full bg-primary/15" style="top: 45%; right: 8%;"></div>
    <div class="hero-dot hidden md:block absolute w-1.5 h-1.5 rounded-full bg-tertiary/25" style="top: 70%; right: 25%;"></div>

    <!-- Noise texture -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 200px;"></div>
  </div>

  <!-- Centered content -->
  <div class="w-full max-w-3xl mx-auto px-6 pt-32 md:pt-40 pb-8 flex flex-col items-center text-center relative z-10">
    <!-- Badge (like Meizon's star badge) -->
    <div class="hero-badge inline-flex items-center gap-2.5 px-5 py-2 rounded-full border border-neutral-200/80 bg-white/90 backdrop-blur-sm shadow-[0_1px_3px_rgba(0,0,0,0.04)] mb-8">
      <span class="w-5 h-5 bg-tertiary/15 rounded-full flex items-center justify-center">
        <i class="fas fa-star text-tertiary text-[10px]"></i>
      </span>
      <span class="text-sm font-medium text-neutral-600">Tecnología NFC para pagos simples</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-title text-[2.25rem] md:text-[3.25rem] lg:text-[3.75rem] font-bold text-neutral-900 leading-[1.08] tracking-tight">
      Crea experiencias de pago <span class="text-tertiary">simples</span> y seguras<span class="text-tertiary">.</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle text-neutral-500 text-base md:text-lg mt-6 max-w-xl leading-relaxed">
      Tecnología innovadora que conecta a las personas para simplificar la vida, con alegría.
    </p>

    <!-- Primary CTA (gold/yellow like Meizon) -->
    <div class="hero-cta mt-10">
      <a
        href="/contacto"
        class="hero-cta-primary group inline-flex items-center gap-2 bg-tertiary text-neutral-900 px-9 py-3.5 rounded-full shadow-lg shadow-tertiary/20 text-base font-semibold cursor-trigger relative overflow-hidden transition-all duration-300 hover:shadow-tertiary/30 hover:shadow-xl"
      >
        <span class="relative z-10">¡Conversemos!</span>
      </a>
    </div>


  </div>

  <!-- Device showcase: centered below content, in the grid zone -->
  <div class="relative w-full max-w-4xl mx-auto px-6 pb-6 z-10">
    <div class="hero-device relative flex items-center justify-center">
      <Image
        src={JoiDevice}
        width={1200}
        height={800}
        alt="Dispositivos Joi Solutions — Pulsera NFC y tarjeta para pagos contactless seguros"
        class="w-full max-w-3xl h-auto object-contain relative z-10 drop-shadow-[0_20px_40px_rgba(0,0,0,0.08)]"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Float badge: Contactless -->
      <div class="hero-float-badge absolute -right-2 md:right-8 top-1/4 bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.06)] border border-neutral-100/80 px-3.5 py-2.5 flex items-center gap-2.5 z-20">
        <div class="w-8 h-8 bg-tertiary/10 rounded-lg flex items-center justify-center">
          <i class="fa-brands fa-nfc-symbol text-tertiary text-sm"></i>
        </div>
        <span class="text-xs font-semibold text-neutral-700 hidden sm:block">Contactless</span>
      </div>

      <!-- Float badge: Seguro -->
      <div class="hero-float-badge-2 absolute -left-2 md:left-8 bottom-1/4 bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.06)] border border-neutral-100/80 px-3.5 py-2.5 flex items-center gap-2.5 z-20">
        <div class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center">
          <i class="fas fa-shield-alt text-primary text-sm"></i>
        </div>
        <span class="text-xs font-semibold text-neutral-700 hidden sm:block">Seguro</span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // --- Particle System ---
  const canvas = document.getElementById("hero-particles") as HTMLCanvasElement;
  if (canvas && !prefersReduced) {
    const ctx = canvas.getContext("2d")!;
    let w = 0, h = 0;
    const particles: { x: number; y: number; vx: number; vy: number; r: number; alpha: number; color: string }[] = [];
    const COLORS = ["rgba(200,200,200,", "rgba(253,198,50,", "rgba(32,57,111,"];
    const COUNT = window.innerWidth < 768 ? 20 : 40;
    const CONNECT_DIST = 130;

    function resize() {
      const section = canvas.closest("section")!;
      w = canvas.width = section.offsetWidth;
      h = canvas.height = section.offsetHeight;
    }
    resize();
    window.addEventListener("resize", resize);

    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.5 + 0.5,
        alpha: Math.random() * 0.3 + 0.08,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
      });
    }

    let animFrame: number;
    let globalAlpha = 0;

    // Fade in particles
    gsap.to({ val: 0 }, {
      val: 1, duration: 2, ease: "power2.out",
      onUpdate: function() { globalAlpha = this.targets()[0].val; }
    });

    function draw() {
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = w;
        if (p.x > w) p.x = 0;
        if (p.y < 0) p.y = h;
        if (p.y > h) p.y = 0;

        // Draw particle
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.color + (p.alpha * globalAlpha) + ")";
        ctx.fill();

        // Connect nearby particles
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dx = p.x - p2.x;
          const dy = p.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECT_DIST) {
            const lineAlpha = (1 - dist / CONNECT_DIST) * 0.06 * globalAlpha;
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(180,180,180,${lineAlpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      animFrame = requestAnimationFrame(draw);
    }
    draw();

    // Clean up on page leave
    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(animFrame);
    });
  }

  // --- GSAP Animations ---
  if (!prefersReduced) {
    const titleEl = document.querySelector(".hero-title") as HTMLElement;
    const split = titleEl ? new SplitText(titleEl, { type: "words", aria: "hidden" }) : null;

    const tl = gsap.timeline({
      defaults: { duration: 0.8, ease: "power3.out" },
    });

    // Grid fade in
    tl.fromTo(".hero-grid", { opacity: 0 }, { opacity: 1, duration: 2, ease: "power1.in" }, 0)

    // Orbs: smooth scale + fade
    .fromTo(".hero-orb-1", { opacity: 0, scale: 0.7 }, { opacity: 1, scale: 1, duration: 2.5, ease: "power2.out" }, 0)
    .fromTo(".hero-orb-2", { opacity: 0, scale: 0.6 }, { opacity: 1, scale: 1, duration: 2.5, ease: "power2.out" }, 0.3)

    // Badge: blur-reveal pop
    .fromTo(".hero-badge",
      { opacity: 0, y: -12, scale: 0.92, filter: "blur(6px)" },
      { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: 0.6, ease: "back.out(1.3)" },
      0.1)

    // Title: word-by-word blur reveal cascade
    if (split?.words) {
      tl.fromTo(split.words,
        { opacity: 0, y: 24, filter: "blur(5px)" },
        { opacity: 1, y: 0, filter: "blur(0px)", stagger: 0.045, duration: 1, ease: "power3.out" },
        0.25);
    }

    // Subtitle
    tl.fromTo(".hero-subtitle",
      { opacity: 0, y: 18, filter: "blur(4px)" },
      { opacity: 1, y: 0, filter: "blur(0px)", duration: 0.8, ease: "power3.out" },
      0.55)

    // CTA
    .fromTo(".hero-cta",
      { opacity: 0, y: 14, scale: 0.9, filter: "blur(3px)" },
      { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: 0.6, ease: "back.out(1.4)" },
      0.7)

    // Device
    .fromTo(".hero-device",
      { opacity: 0, y: 60, scale: 0.94, filter: "blur(4px)" },
      { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: 1.2, ease: "power2.out" },
      0.6)

    // Float badges
    .fromTo(".hero-float-badge",
      { opacity: 0, x: 24, scale: 0.8, filter: "blur(4px)" },
      { opacity: 1, x: 0, scale: 1, filter: "blur(0px)", duration: 0.5, ease: "back.out(1.5)" },
      1.3)
    .fromTo(".hero-float-badge-2",
      { opacity: 0, x: -24, scale: 0.8, filter: "blur(4px)" },
      { opacity: 1, x: 0, scale: 1, filter: "blur(0px)", duration: 0.5, ease: "back.out(1.5)" },
      1.4);

    // Dots
    gsap.fromTo(".hero-dot", { opacity: 0, scale: 0 }, {
      opacity: 1, scale: 1, duration: 0.5, stagger: 0.12, ease: "back.out(2)", delay: 1
    });

    // --- Perpetual animations ---

    // Orbs drift
    gsap.to(".hero-orb-1", { x: 30, y: -15, duration: 10, repeat: -1, yoyo: true, ease: "sine.inOut" });
    gsap.to(".hero-orb-2", { x: -25, y: 12, duration: 12, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 2 });

    // Dots pulse gently
    gsap.to(".hero-dot", { scale: 1.3, opacity: 0.5, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut", stagger: 0.4 });

    // Device float
    gsap.to(".hero-device img", {
      y: -6, duration: 3.5, repeat: -1, yoyo: true, ease: "sine.inOut",
    });

    // Float badges hover
    gsap.to(".hero-float-badge", {
      y: -4, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 0.5,
    });
    gsap.to(".hero-float-badge-2", {
      y: 4, duration: 2.8, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 0.8,
    });

    // CTA: magnetic hover
    const ctaBtn = document.querySelector(".hero-cta-primary") as HTMLElement;
    if (ctaBtn) {
      ctaBtn.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = ctaBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(ctaBtn, { x: x * 0.12, y: y * 0.12, scale: 1.03, duration: 0.25, ease: "power2.out" });
      });
      ctaBtn.addEventListener("mouseleave", () => {
        gsap.to(ctaBtn, { x: 0, y: 0, scale: 1, duration: 0.35, ease: "elastic.out(1, 0.5)" });
      });
    }
  } else {
    gsap.set([".hero-grid", ".hero-badge", ".hero-title", ".hero-subtitle", ".hero-cta", ".hero-device", ".hero-float-badge", ".hero-float-badge-2", ".hero-orb"], { opacity: 1, y: 0, x: 0, scale: 1, filter: "blur(0px)" });
    gsap.set(".hero-dot", { opacity: 1, scale: 1 });
  }
</script>
