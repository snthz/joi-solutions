---
import devicePng from "../assets/js-1.png";
import { Image } from "astro:assets";
import ArrowRight from "../icons/ArrowRight.astro";
---

<section class="solutions-section py-16 md:py-24 border-b border-neutral-100">
  <div class="max-w-5xl 3xl:max-w-6xl mx-auto px-6 md:px-10">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <!-- Device image: properly constrained -->
      <div class="solutions-device w-full md:w-1/2 shrink-0">
        <Image
          src={devicePng}
          alt="Plataforma Joi Solutions"
          class="w-full h-auto rounded-2xl shadow-lg shadow-neutral-200/50"
        />
      </div>

      <!-- Text content -->
      <div class="solutions-text w-full md:w-1/2 flex flex-col gap-4 items-center md:items-start text-center md:text-left">
        <span class="text-xs font-semibold tracking-[0.2em] uppercase text-tertiary">Alianzas</span>
        <h3 class="text-2xl md:text-3xl font-bold text-neutral-800 leading-tight">
          Tu negocio, tus clientes
        </h3>
        <p class="text-neutral-500 text-base md:text-lg leading-relaxed max-w-md">
          Nos asociamos para revolucionar la experiencia de pago en escuelas, centros comerciales y eventos. Gana con cada Taq, activa tus promociones y controla un ecosistema cashless. Es tu oportunidad de adquirir nuevos ingresos.
        </p>
        <div class="mt-4">
          <a
            href="/joi-taq"
            class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-full shadow-md font-medium cursor-trigger transition-all duration-300 hover:shadow-lg hover:shadow-primary/15"
          >
            <span>Ver más</span>
            <ArrowRight class="stroke-neutral-100" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .solutions-section { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    .solutions-section { opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector(".solutions-section") as HTMLElement;
  const device = document.querySelector(".solutions-device") as HTMLElement;
  const text = document.querySelector(".solutions-text") as HTMLElement;
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (section && !prefersReduced) {
    // Fade in the whole section
    gsap.fromTo(section,
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 80%", toggleActions: "play none none none" }
      }
    );

    // Image slides from left
    if (device) {
      gsap.fromTo(device,
        { opacity: 0, x: -30 },
        {
          opacity: 1, x: 0, duration: 0.7, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", toggleActions: "play none none none" }
        }
      );
    }

    // Text slides from right
    if (text) {
      gsap.fromTo(text,
        { opacity: 0, x: 30 },
        {
          opacity: 1, x: 0, duration: 0.7, ease: "power2.out", delay: 0.15,
          scrollTrigger: { trigger: section, start: "top 75%", toggleActions: "play none none none" }
        }
      );
    }
  } else if (section) {
    gsap.set(section, { opacity: 1 });
    if (device) gsap.set(device, { opacity: 1, x: 0 });
    if (text) gsap.set(text, { opacity: 1, x: 0 });
  }
</script>

